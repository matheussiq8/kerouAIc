{
  "manifest_version": 3,
  "name": "kerouAIc",
  "version": "0.1",
  "description": "Rewrite LinkedIn posts in a Kerouac-inspired voice using OpenAI or OpenRouter.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://api.openai.com/*",
    "https://openrouter.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "kerouAIc"
  }
}
